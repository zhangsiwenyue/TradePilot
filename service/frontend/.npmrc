; TradePilot frontend npm config.
; Pin the registry to the public npmjs.org so deploys (Render, CI, anywhere)
; never accidentally pick up a developer's private/internal token via a parent
; .npmrc on the build host. All declared deps are public.
registry=https://registry.npmjs.org/
; Don't break the install on optional postinstall scripts in transitive deps.
fund=false
audit=false
